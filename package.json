{
  "name": "i2p-node",
  "version": "1.0.0",
  "description": "Complete I2P Router implementation in TypeScript",
  "main": "dist/index.js",
  "types": "dist/index-exports.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index-exports.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node --esm src/index.ts",
    "watch": "tsc --watch",
    "test": "node --test dist/**/*.test.js",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "i2p",
    "router",
    "anonymous",
    "privacy",
    "p2p"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@noble/ciphers": "^0.5.0",
    "@noble/curves": "^1.3.0",
    "@noble/hashes": "^1.3.3",
    "adm-zip": "^0.5.16"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.7",
    "@types/node": "^20.10.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
